{
  "name": "@anthropic-fans/tmux-bridge",
  "version": "0.2.0",
  "description": "Standalone MCP server + CLI adapters for cross-pane AI agent communication via tmux",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tmux-bridge": "dist/index.js",
    "tmux-bridge-mcp": "dist/index.js",
    "kimi-tmux": "dist/kimi-adapter.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
